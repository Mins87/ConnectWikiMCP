# ConnectWikiMCP Environment Variables Template
# Copy this file to .env and fill in your values.

# [Wiki Settings]
# Absolute local path where wiki data is stored
WIKI_ROOT_PATH=./wiki

# [MCP Server Settings]
# Transport protocol: 'stdio', 'sse', or 'hybrid' (both)
MCP_TRANSPORT=hybrid
# Service port to use when SSE is enabled
MCP_PORT=8000

# [LLM Backend Settings]
# Preferred LLM engine: 'ollama', 'llamacpp', or 'external'
LOCAL_LLM_TYPE=ollama
# API endpoint for your LLM (e.g., http://localhost:11434 for Ollama)
LOCAL_LLM_API_URL=http://host.docker.internal:11434
# Model name to use for knowledge processing
LOCAL_LLM_MODEL=gemma4-E4B-it
# (Optional) API key if using an external LLM provider
LOCAL_LLM_API_KEY=
