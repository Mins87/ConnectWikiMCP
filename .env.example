# 🚀 ConnectWikiMCP v2.1 Configuration

# 📁 Core Path Settings
# The root directory for wiki pages, raw sources, and logs.
WIKI_ROOT_PATH=./wiki

# 🧠 LLM Backend Settings (Ollama / Llama.cpp / OpenAI-Compatible)
# Options: ollama, llamacpp, external
LOCAL_LLM_TYPE=ollama
LOCAL_LLM_API_URL=http://localhost:11434
LOCAL_LLM_MODEL=gemma4-E4B-it
LOCAL_LLM_API_KEY=

# 📡 Network & System
# Port for the Streamable HTTP transport (MCP interaction)
MCP_PORT=15252
PYTHON_COMMAND=python

# 🛰️ Antigravity Watch (v2.1)
# Absolute path to the Antigravity/brain directory to auto-ingest session logs.
# Leave empty to disable.
BRAIN_WATCH_PATH=

# Ingestion cycle interval in minutes. (Default: 30)
ANTIGRAVITY_WATCH_INTERVAL=30

# Note: Embedding settings (v2.0) have been removed in favor of 
# the 3-Layer Semantic Pipeline in v2.1.
