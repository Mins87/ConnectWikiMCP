# ConnectWikiMCP Environment Configuration Template
# Copy this file to .env and fill in your values.

# [Wiki Core Settings]
# Host path where wiki data is stored (Mapped as volume in Docker)
WIKI_ROOT_PATH=./wiki

# [Network Settings]
# Transport: 'http' (Streamable HTTP / Web) or 'stdio' (Direct local)
# Use 'http' for Docker/Cloud deployments.
MCP_TRANSPORT=http
# Port used for Streamable HTTP server
MCP_PORT=15252

# [AI & Semantic Search Settings]
# LLM Provider: 'ollama', 'llamacpp', or 'external' (OpenAI compatible)
LOCAL_LLM_TYPE=ollama
# Local LLM endpoint (typically Ollama or LlamaCpp server)
LOCAL_LLM_API_URL=http://host.docker.internal:11434
# Model name for synthesis, summary, and analysis
# Recommended: gemma:4b, llama3:8b, etc.
LOCAL_LLM_MODEL=gemma:4b
# Model name for vector embeddings (Search)
# Run `ollama pull nomic-embed-text` first
EMBEDDING_MODEL=nomic-embed-text
# Optional API key for 'external' type or authenticated endpoints
LOCAL_LLM_API_KEY=

# [Autonomous Evolution Settings]
# How often to run auto-evolution logic (hours)
# Set to 0 to disable background maintenance
EVOLUTION_INTERVAL_HOURS=6

# [Conversation Auto-Capture]
# Path to Antigravity brain directory for auto-ingesting conversation logs.
# Leave empty to disable the conversation watcher.
# Example (Windows): C:\Users\<username>\.gemini\antigravity\brain
# Example (Linux):   /home/<username>/.gemini/antigravity/brain
BRAIN_WATCH_PATH=
# Scan interval in minutes (0 = disabled, only manual via IngestConversations tool)
CONVERSATION_WATCH_INTERVAL=30
